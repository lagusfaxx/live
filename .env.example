# ---------- LiveKit público ----------
# URL pública que usará tu app cliente (siempre wss en producción)
LIVEKIT_URL=wss://live.example.com

# CORS para token-service (separa múltiples orígenes con coma)
ALLOWED_ORIGIN=https://tuapp.com,https://www.tuapp.com

# ---------- Credenciales LiveKit ----------
LIVEKIT_API_KEY=LK_API_KEY_REPLACE_ME
LIVEKIT_API_SECRET=LK_API_SECRET_REPLACE_ME_WITH_LONG_RANDOM_VALUE

# ---------- Auth interna token-service ----------
# Tu backend debe enviar: Authorization: Bearer <este_valor>
SHARED_BEARER_TOKEN=REPLACE_ME_WITH_LONG_RANDOM_TOKEN

# ---------- TURN / coturn ----------
# IP pública real del servidor donde corre Coolify
PUBLIC_IPV4=203.0.113.10
TURN_REALM=turn.example.com
TURN_STATIC_AUTH_SECRET=REPLACE_ME_WITH_LONG_RANDOM_TURN_SECRET

# ---------- Comportamiento token-service ----------
DEFAULT_CAN_PUBLISH=false
