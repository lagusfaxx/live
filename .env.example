# --- DNS / public endpoints ---
LIVEKIT_URL=wss://live.example.com
ALLOWED_ORIGIN=https://uzeed.cl

# --- LiveKit credentials ---
LIVEKIT_API_KEY=LK_API_KEY_REPLACE_ME
LIVEKIT_API_SECRET=LK_API_SECRET_REPLACE_ME_WITH_A_LONG_SECRET

# --- Internal auth for the token API ---
# Send: Authorization: Bearer <this-value>
SHARED_BEARER_TOKEN=REPLACE_ME_WITH_A_LONG_RANDOM_TOKEN

# --- TURN config placeholders ---
PUBLIC_IPV4=203.0.113.10
TURN_REALM=turn.example.com
TURN_STATIC_AUTH_SECRET=REPLACE_ME_WITH_A_LONG_RANDOM_SECRET

# --- Behavior ---
DEFAULT_CAN_PUBLISH=false
